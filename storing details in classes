class Student {
    String name;
    int age;
    String Hobby;
    String city;
    

    Student(String name, int age, String Hobby,String city) {
        this.name = name;
        this.age = age;
        this.Hobby=Hobby;
        this.city=city;
    }

    void display() {
        System.out.println("Name: " + name);
        System.out.println("Age: " + age);
        System.out.println("Hobby:"+Hobby);
        System.out.println("city: "+city);
    }
}
