class Parent{
    void print() {System.out.println("Name: Harish (parent class)");
        
    }
    }
    class Subclass extends Parent{
        void print() {System.out.println(" Age: 20(subclass)");
    }
    }
    class Subclass1 extends Parent{
        void print() {System.out.println(" full stack(subclass1)");
            
        }
    }
    class Subclass2 extends Parent {
        void print() {System.out.println(" Front end & backend(subclass2)");
            
        }
    }
    class Main {
        public static void main(String[] args){
            Parent a;
            a = new Subclass1();
            a.print();
            a = new Subclass2();
            a.print();
        }
    }
    
